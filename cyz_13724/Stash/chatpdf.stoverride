name: |-
  chatpdf
desc: |-
  无

http:

  mitm:
    - "api.revenuecat.com"

  script:  
  - match: ^https?:\/\/api\.revenuecat\.com\/v1\/(subscribers\/[^\/]+$|receipts$)
    name: chatpdf_69
    type: response
    require-body: true
    max-size: -1
    timeout: 60


script-providers:
  "chatpdf_69":
    url: https://raw.githubusercontent.com/axtyet/Quan-X/main/cyz_13724/scripts/chatpdf.js
    interval: 86400

